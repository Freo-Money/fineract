<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">
    <changeSet author="fineract" id="1" context="postgresql">
        <sql>
            SELECT SETVAL('c_configuration_id_seq', COALESCE(MAX(id), 0)+1, false ) FROM c_configuration;
        </sql>
    </changeSet>
    <changeSet author="fineract" id="2">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM c_configuration WHERE name = 'fineract-migration-cutoff-date'
            </sqlCheck>
        </preConditions>
        <insert tableName="c_configuration">
            <column name="name" value="fineract-migration-cutoff-date"/>
            <column name="value"/>
            <column name="date_value"/>
            <column name="string_value"/>
            <column name="enabled" valueBoolean="false"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description" value="Cutoff date for applying overdue charges to migrated loans. Charges will only be applied from this date forward. Set date_value to the migration date."/>
        </insert>
    </changeSet>
    <changeSet author="fineract" id="3">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM c_configuration WHERE name = 'fineract-migration-last-imported-loan-id'
            </sqlCheck>
        </preConditions>
        <insert tableName="c_configuration">
            <column name="name" value="fineract-migration-last-imported-loan-id"/>
            <column name="value"/>
            <column name="date_value"/>
            <column name="string_value"/>
            <column name="enabled" valueBoolean="false"/>
            <column name="is_trap_door" valueBoolean="false"/>
            <column name="description" value="Maximum loan ID that was imported during migration. Loans with ID &lt;= this value will use the migration cutoff date for overdue charge application."/>
        </insert>
    </changeSet>
</databaseChangeLog>
