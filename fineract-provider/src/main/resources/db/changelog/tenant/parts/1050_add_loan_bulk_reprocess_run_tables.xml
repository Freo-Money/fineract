<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet author="fineract" id="1050-1">
        <createTable tableName="m_loan_bulk_reprocess_run">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_on_utc" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_on_utc" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="batch_size" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="total_loan_ids" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="processed_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="failed_count" type="INT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="started_date" type="DATETIME"/>
            <column name="finished_date" type="DATETIME"/>
            <column name="error_message" type="VARCHAR(2000)"/>
        </createTable>

        <createIndex indexName="idx_m_lbr_run_status" tableName="m_loan_bulk_reprocess_run">
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet author="fineract" id="1050-2">
        <createTable tableName="m_loan_bulk_reprocess_run_item">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="run_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="loan_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="VARCHAR(2000)"/>
            <column name="processed_date" type="DATETIME"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="m_loan_bulk_reprocess_run_item" baseColumnNames="run_id"
                                 referencedTableName="m_loan_bulk_reprocess_run" referencedColumnNames="id"
                                 constraintName="fk_m_lbr_item_run"/>

        <addUniqueConstraint tableName="m_loan_bulk_reprocess_run_item"
                             columnNames="run_id, loan_id"
                             constraintName="uq_m_lbr_item_run_loan"/>

        <!--
            Index covers the reader's hot query: select id, loan_id from m_loan_bulk_reprocess_run_item
            where run_id = ? and status = 'PENDING' order by id asc.
            Including id keeps the order-by index-served (no filesort) and lets the index satisfy the
            count(*) for failures pagination.
        -->
        <createIndex indexName="idx_m_lbr_item_run_status_id" tableName="m_loan_bulk_reprocess_run_item">
            <column name="run_id"/>
            <column name="status"/>
            <column name="id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
